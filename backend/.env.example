# ─── VIMS Timetable Backend Environment Configuration ───────────────────────
# Copy this file to `.env` and fill in the values.
# The other team (portal integration) must set these before deployment.

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use local SQLite (dev). Set to Postgres URL for production.
# DATABASE_URL=postgresql://user:password@host:5432/vims_timetable

# ── JWT Security ──────────────────────────────────────────────────────────────
# REQUIRED: Change to a long random string. Never share this key.
SECRET_KEY=CHANGE_ME_TO_LONG_RANDOM_STRING_BEFORE_DEPLOYMENT

# ── Grid Challenge (provided by college IT) ───────────────────────────────────
# These are the two dynamic grid values staff must enter at login.
# The CHALLENGE is the label shown to staff (e.g. "B3").
# The VALUE is the expected answer (case-insensitive).
# Leave VALUE blank to disable that grid check.
GRID_CHALLENGE_1=B3
GRID_VALUE_1=

GRID_CHALLENGE_2=D5
GRID_VALUE_2=
